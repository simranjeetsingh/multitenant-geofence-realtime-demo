# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your local environment.
# ----------------------------------------------------------------------------

# PostgreSQL connection string (must point at a database with PostGIS available).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/screening_demo?schema=public"

# Port the combined Next.js + Socket.io server listens on.
PORT=3000

# Node environment: development | production
NODE_ENV=development
